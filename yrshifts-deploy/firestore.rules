rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isTrialValid() {
      let path = /databases/$(database)/documents/settings/company;
      return !exists(path) 
        || !('trialExpiresAt' in get(path).data) 
        || request.time < get(path).data.trialExpiresAt;
    }

    function isSignedIn() { return request.auth != null && isTrialValid(); }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin()   { return isSignedIn() && userRole() in ['owner', 'admin', 'manager']; }
    function isOwner()   { return isSignedIn() && userRole() == 'owner'; }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isSignedIn();
      allow create: if isAdmin();
      allow delete: if isAdmin();
      allow update: if isAdmin()
        || (isSignedIn()
            && request.auth.uid == userId
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
    }

    // ── Shifts ────────────────────────────────────────────────────────────────
    match /shifts/{shiftId} {
      // Teachers read only their own shifts and the open (claimable) pool.
      // Admin dashboard reads the whole collection via isAdmin().
      allow read:   if isAdmin()
        || (isSignedIn() && resource.data.instructorId == request.auth.uid)
        || (isSignedIn() && resource.data.claimable == true);
      allow create: if isAdmin();
      allow delete: if isAdmin();
      allow update: if isAdmin()
        || (isSignedIn()
            && resource.data.instructorId == request.auth.uid
            && request.resource.data.diff(resource.data)
               .affectedKeys().hasOnly(['confirmationStatus']))
        || (isSignedIn()
            && resource.data.claimable == true
            && resource.data.instructorId == null
            && request.resource.data.diff(resource.data)
               .affectedKeys().hasOnly(['instructorId','claimable','confirmationStatus']));
    }

    // ── Settings ──────────────────────────────────────────────────────────────
    match /settings/{docId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Knowledge Base ────────────────────────────────────────────────────────
    match /kb_nodes/{nodeId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Weekly Buzz ───────────────────────────────────────────────────────────
    match /weekly_buzz/{postId} {
      function validSeenBy() {
        let oldSeen = 'seenBy' in resource.data ? resource.data.seenBy : [];
        let newSeen = request.resource.data.seenBy;
        return newSeen.removeAll(oldSeen).hasOnly([request.auth.uid])
            && oldSeen.removeAll(newSeen).size() == 0;
      }

      function validLikes() {
        let oldLikes = 'likes' in resource.data ? resource.data.likes : [];
        let newLikes = request.resource.data.likes;
        return newLikes.removeAll(oldLikes).hasOnly([request.auth.uid])
            && oldLikes.removeAll(newLikes).hasOnly([request.auth.uid]);
      }

      function validComments() {
        let oldComments = 'comments' in resource.data ? resource.data.comments : [];
        let newComments = request.resource.data.comments;
        let added = newComments.removeAll(oldComments);
        // No removals ever (moderation is admin-only), and any addition is
        // exactly one comment authored by the requester.
        return oldComments.removeAll(newComments).size() == 0
          && (
            added.size() == 0 || (
              added.size() == 1 &&
              added[0].userId == request.auth.uid &&
              newComments.size() == oldComments.size() + 1
            )
          );
      }

      allow read:   if isSignedIn();
      allow create: if isAdmin();
      allow delete: if isAdmin();
      allow update: if isAdmin()
        || (isSignedIn()
            && request.resource.data.diff(resource.data)
               .affectedKeys().hasOnly(['seenBy', 'likes', 'comments'])
            && validSeenBy()
            && validLikes()
            && validComments());
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read:   if isAdmin() || (isSignedIn() && resource.data.recipientId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.recipientId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ── Events ────────────────────────────────────────────────────────────────
    match /events/{eventId} {
      function validRsvps() {
        let oldRsvps = 'rsvps' in resource.data ? resource.data.rsvps : {};
        let newRsvps = 'rsvps' in request.resource.data ? request.resource.data.rsvps : {};
        return newRsvps.diff(oldRsvps).affectedKeys().hasOnly([request.auth.uid]);
      }

      allow read:   if isSignedIn();
      allow create: if isAdmin();
      allow delete: if isAdmin();
      allow update: if isAdmin()
        || (isSignedIn()
            && request.resource.data.diff(resource.data)
               .affectedKeys().hasOnly(['rsvps'])
            && validRsvps());
    }

    // ── Reminders (written by Cloud Functions only — no client access needed) ──
    match /reminders/{reminderId} {
      allow read:  if isAdmin();
      allow write: if false;   // Cloud Functions use Admin SDK — bypasses these rules
    }

    // ── Chat ──────────────────────────────────────────────────────────────────
    // Admins: full access (the admin dashboard listens to the whole collection).
    // Teachers: access only to chats they are a member of.
    //   - Chat doc updates limited to the fields the teacher app writes:
    //     lastMessage/lastAt (on send), lastRead (mark read), pinnedAt (pin).
    //   - DM creates allowed for teachers only if they are a member.
    //   - Messages: create only as yourself, update only reactions,
    //     delete only your own messages.
    // Cloud Functions (push fan-out) use the Admin SDK and bypass these rules.
    match /chats/{chatId} {
      function isChatMember() {
        return request.auth.uid
          in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
      }

      allow read:   if isAdmin()
        || (isSignedIn() && request.auth.uid in resource.data.members);
      allow create: if isSignedIn() && (
        isAdmin() ||
        (
          request.resource.data.isGroup == false &&
          request.auth.uid in request.resource.data.members
        )
      );
      allow delete: if isAdmin();
      allow update: if isAdmin()
        || (isSignedIn()
            && request.auth.uid in resource.data.members
            && request.resource.data.diff(resource.data)
               .affectedKeys().hasOnly(['lastMessage', 'lastAt', 'lastRead', 'pinnedAt']));

      match /messages/{msgId} {
        allow read:   if isAdmin() || (isSignedIn() && isChatMember());
        allow create: if isAdmin()
          || (isSignedIn()
              && isChatMember()
              && request.resource.data.authorId == request.auth.uid);
        allow update: if isAdmin()
          || (isSignedIn()
              && isChatMember()
              && request.resource.data.diff(resource.data)
                 .affectedKeys().hasOnly(['reactions']));
        allow delete: if isAdmin()
          || (isSignedIn() && resource.data.authorId == request.auth.uid);
      }
    }

    // ── Forms Templates ──────────────────────────────────────────────────────────
    match /forms/{formId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Forms Assigned ──────────────────────────────────────────────────────────
    match /forms_assigned/{assignmentId} {
      allow read:   if isAdmin() || (isSignedIn() && resource.data.teacherId == request.auth.uid);
      allow create: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && resource.data.teacherId == request.auth.uid);
      allow delete: if isAdmin();
    }
  }
}
