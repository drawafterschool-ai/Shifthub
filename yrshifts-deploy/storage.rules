rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profile photos — owner can write, anyone signed in can read
    match /profile_photos/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Chat attachments — any signed-in user can read and write
    match /chat_attachments/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024; // 10MB max
    }

    // Knowledge base files — any signed-in user can read, admin writes
    match /kb_files/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
