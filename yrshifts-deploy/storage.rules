rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['owner', 'admin', 'manager'];
    }

    // ── Profile Photos ────────────────────────────────────────────────────────
    match /profile_photos/{userId} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // ── Knowledge Base ────────────────────────────────────────────────────────
    match /kb/{fileName} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Group Icons ───────────────────────────────────────────────────────────
    match /group_icons/{fileName} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Chat Attachments ──────────────────────────────────────────────────────
    match /chat_attachments/{fileName} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // ── Shift Attachments ─────────────────────────────────────────────────────
    match /shift_attachments/{fileName} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}
