import { useState, useRef, useEffect, useCallback } from 'react'
import { ref as stRef, uploadBytes, getDownloadURL } from 'firebase/storage'
import { storage } from '../../utils/firebase'
import { resizeFile } from '../../utils/resizeFile'
import useChatStore      from '../../stores/useChatStore'
import useAuthStore      from '../../stores/useAuthStore'
import useDirectoryStore from '../../stores/useDirectoryStore'
import Avatar            from '../../components/Avatar'
import Button            from '../../components/Button'
import Modal, { ModalHeader, ModalFooter } from '../../components/Modal'

const uid = () => Math.random().toString(36).slice(2)

const EMOJIS = ['👍','❤️','😂','😮','😢','🔥','🎉','👏','💯','🙏']

function fmtTime(ts) {
  if (!ts) return ''
  const d = ts.seconds ? new Date(ts.seconds * 1000) : new Date(ts)
  const now = new Date()
  const diff = now - d
  if (diff < 60000) return 'Just now'
  if (diff < 3600000) return `${Math.floor(diff / 60000)}m ago`
  if (d.toDateString() === now.toDateString()) return d.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' })
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' })
}

// ── Image Album ───────────────────────────────────────────────────────────────
function ImageAlbum({ images, isMine }) {
  const n = images.length
  if (n === 0) return null
  if (n === 1) return (
    <a href={images[0].url} target="_blank" rel="noreferrer" className="block mb-1">
      <img src={images[0].url} alt="" className="rounded-xl max-h-48 max-w-[260px] object-cover block" />
    </a>
  )
  const grid = n === 2 ? 'grid-cols-2' : n === 3 ? 'grid-cols-3' : 'grid-cols-2'
  return (
    <div className={`grid ${grid} gap-0.5 rounded-xl overflow-hidden mb-1`} style={{ maxWidth: 260 }}>
      {images.map((img, i) => (
        <a key={img.id} href={img.url} target="_blank" rel="noreferrer"
          className="block overflow-hidden" style={{ aspectRatio: '1' }}>
          <img src={img.url} alt="" className="w-full h-full object-cover" />
        </a>
      ))}
    </div>
  )
}

// ── Message Bubble ────────────────────────────────────────────────────────────
function Bubble({ msg, isMine, onReact, onReply, onForward, onDelete }) {
  const [showActions, setShowActions] = useState(false)
  const [showEmoji,   setShowEmoji]   = useState(false)

  const images = (msg.attachments || []).filter(a => a.type?.startsWith('image/'))
  const files  = (msg.attachments || []).filter(a => !a.type?.startsWith('image/'))
  const hasReactions = msg.reactions && Object.keys(msg.reactions).length > 0

  return (
    <div className={`flex gap-2 mb-3 group ${isMine ? 'flex-row-reverse' : 'flex-row'}`}>
      <div className={`flex flex-col ${isMine ? 'items-end' : 'items-start'} max-w-[75%]`}>

        {/* Reply preview */}
        {msg.replyTo && (
          <div className={`text-xs px-2 py-1 rounded-lg mb-1 border-l-2 border-accent opacity-70 max-w-full
            ${isMine ? 'bg-accent/10 text-right' : 'bg-raised'}`}>
            <p className="font-semibold text-accent">{msg.replyTo.authorName}</p>
            <p className="text-dim truncate">{msg.replyTo.text || '📎 Attachment'}</p>
          </div>
        )}

        {/* Bubble */}
        <div className="relative">
          <div
            onClick={() => setShowActions(v => !v)}
            className={`px-3 py-2 rounded-2xl cursor-pointer select-none max-w-full
              ${isMine
                ? 'bg-accent text-white rounded-br-sm'
                : 'bg-card border border-app text-primary rounded-bl-sm'}`}
          >
            <ImageAlbum images={images} isMine={isMine} />
            {files.map(f => (
              <a key={f.id} href={f.url} target="_blank" rel="noreferrer"
                className={`flex items-center gap-2 px-2.5 py-1.5 rounded-lg text-xs font-semibold no-underline mb-1
                  ${isMine ? 'bg-white/20 text-white' : 'bg-raised text-primary'}`}>
                📄 {f.name}
              </a>
            ))}
            {msg.text && <p className="text-sm leading-relaxed whitespace-pre-wrap break-words">{msg.text}</p>}
          </div>

          {/* Actions */}
          {showActions && (
            <div className={`absolute bottom-full mb-1 z-20 flex items-center gap-1 bg-surface border border-app rounded-xl p-1 shadow-xl
              ${isMine ? 'right-0' : 'left-0'}`}>
              <button onClick={() => { setShowEmoji(v => !v); setShowActions(false) }}
                className="p-1.5 hover:bg-raised rounded-lg text-sm cursor-pointer bg-transparent border-none" title="React">😊</button>
              <button onClick={() => { onReply(); setShowActions(false) }}
                className="p-1.5 hover:bg-raised rounded-lg text-sm cursor-pointer bg-transparent border-none" title="Reply">↩️</button>
              <button onClick={() => { onForward(); setShowActions(false) }}
                className="p-1.5 hover:bg-raised rounded-lg text-sm cursor-pointer bg-transparent border-none" title="Forward">↗️</button>
              {onDelete && (
                <button onClick={() => { if (window.confirm('Delete this message?')) { onDelete(); } setShowActions(false) }}
                  className="p-1.5 hover:bg-danger-soft rounded-lg text-sm cursor-pointer bg-transparent border-none text-danger" title="Delete">🗑</button>
              )}
            </div>
          )}

          {/* Emoji picker */}
          {showEmoji && (
            <div className={`absolute bottom-full mb-1 z-20 flex gap-1 bg-surface border border-app rounded-xl p-2 shadow-xl
              ${isMine ? 'right-0' : 'left-0'}`}>
              {EMOJIS.map(e => (
                <button key={e} onClick={() => { onReact(e); setShowEmoji(false) }}
                  className="text-lg hover:scale-125 transition-transform cursor-pointer bg-transparent border-none p-0.5">
                  {e}
                </button>
              ))}
            </div>
          )}
        </div>

        {/* Reactions */}
        {hasReactions && (
          <div className="flex flex-wrap gap-1 mt-1">
            {Object.entries(msg.reactions).map(([emoji, users]) => users.length > 0 && (
              <button key={emoji} onClick={() => onReact(emoji)}
                className="flex items-center gap-1 px-2 py-0.5 rounded-full bg-raised border border-app text-xs cursor-pointer hover:border-accent">
                {emoji} <span className="text-muted">{users.length}</span>
              </button>
            ))}
          </div>
        )}

        <p className="text-[10px] text-dim mt-0.5 px-1">{fmtTime(msg.createdAt)}</p>
      </div>
    </div>
  )
}

// ── New Chat Modal ────────────────────────────────────────────────────────────
function NewChatModal({ onClose, onCreate, adminId, userProfile }) {
  const { instructors }          = useDirectoryStore()
  const [step,      setStep]     = useState('pick')
  const [sel,       setSel]      = useState(null)
  const [groupName, setGroupName]= useState('')
  const [q,         setQ]        = useState('')
  const [busy,      setBusy]     = useState(false)

  const canCreateGroup = ['owner','admin'].includes(userProfile?.role)
  const teacherIds     = instructors.map(i => i.id)

  const createInstant = async (opts) => {
    setBusy(true)
    try { await onCreate(opts); onClose() }
    finally { setBusy(false) }
  }

  const filtered = instructors.filter(i =>
    i.id !== adminId &&
    `${i.firstName} ${i.lastName}`.toLowerCase().includes(q.toLowerCase())
  )

  // Step: pick type
  if (step === 'pick') return (
    <Modal onClose={onClose}>
      <ModalHeader title="New conversation" onClose={onClose} />
      <div className="flex flex-col gap-3">
        {canCreateGroup && (
          <button onClick={() => setStep('group')}
            className="flex items-center gap-4 p-4 rounded-2xl border border-app bg-raised hover:border-accent/50 cursor-pointer text-left w-full">
            <div className="w-11 h-11 rounded-xl bg-accent-soft flex items-center justify-center text-xl flex-shrink-0">👥</div>
            <div>
              <p className="text-sm font-bold text-primary">New group chat</p>
              <p className="text-xs text-muted mt-0.5">All team members</p>
            </div>
          </button>
        )}
        <button onClick={() => setStep('dm')}
          className="flex items-center gap-4 p-4 rounded-2xl border border-app bg-raised hover:border-accent/50 cursor-pointer text-left w-full">
          <div className="w-11 h-11 rounded-xl bg-accent-soft flex items-center justify-center text-xl flex-shrink-0">💬</div>
          <div>
            <p className="text-sm font-bold text-primary">New direct message</p>
            <p className="text-xs text-muted mt-0.5">One-on-one conversation</p>
          </div>
        </button>
      </div>
    </Modal>
  )

  // Step: name the group
  if (step === 'group') return (
    <Modal onClose={onClose} width="max-w-sm">
      <ModalHeader title="New group chat" onClose={onClose} />
      <div className="flex flex-col gap-4">
        <div>
          <label className="block text-xs font-semibold text-muted uppercase tracking-wide mb-1.5">Group name</label>
          <input value={groupName} onChange={e => setGroupName(e.target.value)}
            placeholder="e.g. Spring 2025 Team" autoFocus
            className="w-full bg-raised border border-app rounded-xl px-4 py-3 text-sm text-primary placeholder:text-dim outline-none focus:border-accent" />
        </div>
      </div>
      <ModalFooter>
        <Button onClick={() => setStep('pick')}>← Back</Button>
        <Button variant="primary" disabled={!groupName.trim() || busy}
          onClick={() => createInstant({ name: groupName.trim(), members: [...teacherIds, adminId], isGroup: true, createdBy: adminId })}>
          {busy ? 'Creating…' : 'Create group'}
        </Button>
      </ModalFooter>
    </Modal>
  )

  // Step: pick a person for DM
  if (step === 'dm') return (
    <Modal onClose={onClose} width="max-w-sm">
      <ModalHeader title="New direct message" onClose={onClose} />
      <input value={q} onChange={e => setQ(e.target.value)} placeholder="Search people…" autoFocus
        className="w-full bg-raised border border-app rounded-xl px-4 py-2.5 text-sm text-primary placeholder:text-dim outline-none focus:border-accent mb-3" />
      <div className="max-h-64 overflow-y-auto flex flex-col gap-1 -mx-2">
        {filtered.map(i => (
          <button key={i.id} onClick={() => setSel(sel === i.id ? null : i.id)}
            className={`flex items-center gap-3 px-3 py-2.5 rounded-xl cursor-pointer text-left w-full transition-colors border
              ${sel === i.id ? 'bg-accent-soft border-accent/30' : 'bg-transparent border-transparent hover:bg-raised'}`}>
            <Avatar firstName={i.firstName} lastName={i.lastName} color={i.color} photo={i.photo} size={36} />
            <div className="flex-1 min-w-0">
              <p className="text-sm font-semibold text-primary">{i.firstName} {i.lastName}</p>
              <p className="text-xs text-dim capitalize">{i.role}</p>
            </div>
            {['owner','admin'].includes(i.role) && (
              <span className="text-xs px-1.5 py-0.5 rounded-md bg-accent-soft text-accent font-semibold">
                {i.role === 'owner' ? '👑' : '🛡️'}
              </span>
            )}
          </button>
        ))}
      </div>
      <ModalFooter>
        <Button onClick={() => setStep('pick')}>← Back</Button>
        <Button variant="primary" disabled={!sel || busy}
          onClick={() => {
            const person = instructors.find(i => i.id === sel)
            const name = `${person?.firstName || ''} ${person?.lastName || ''}`.trim()
            createInstant({ name, members: [sel, adminId], isGroup: false, createdBy: adminId })
          }}>
          {busy ? 'Opening…' : 'Start chat'}
        </Button>
      </ModalFooter>
    </Modal>
  )
}

// ── Forward Modal ─────────────────────────────────────────────────────────────
function ForwardModal({ msg, chats, activeChatId, onForward, onClose }) {
  const [sel, setSel] = useState(null)
  const list = chats.filter(c => c.id !== activeChatId)
  return (
    <Modal onClose={onClose} width="max-w-sm">
      <ModalHeader title="Forward message" onClose={onClose} />
      <div className="max-h-64 overflow-y-auto flex flex-col gap-1 -mx-2">
        {list.map(c => (
          <button key={c.id} onClick={() => setSel(c.id)}
            className={`flex items-center gap-3 px-3 py-2.5 rounded-xl cursor-pointer text-left w-full border transition-colors
              ${sel === c.id ? 'bg-accent-soft border-accent/30' : 'bg-transparent border-transparent hover:bg-raised'}`}>
            <div className="w-9 h-9 rounded-xl bg-accent-soft flex items-center justify-center text-base flex-shrink-0">
              {c.isGroup ? '👥' : '💬'}
            </div>
            <p className="text-sm font-semibold text-primary truncate">{c.name}</p>
          </button>
        ))}
      </div>
      <ModalFooter>
        <Button onClick={onClose}>Cancel</Button>
        <Button variant="primary" disabled={!sel} onClick={() => { onForward(sel); onClose() }}>Forward</Button>
      </ModalFooter>
    </Modal>
  )
}

// ── Main Component ────────────────────────────────────────────────────────────
export default function ChatView() {
  const {
    chats, messages, activeChatId, loading,
    setActiveChat, markChatRead, sendMessage,
    addReaction, pinChat, deleteMessage, deleteChat, createChat,
  } = useChatStore()
  const { user, userProfile }  = useAuthStore()
  const { instructors }        = useDirectoryStore()

  const [showList,    setShowList]    = useState(true)
  const [q,          setQ]           = useState('')
  const [msgText,    setMsgText]     = useState('')
  const [replyTo,    setReplyTo]     = useState(null)
  const [forwardMsg, setForwardMsg]  = useState(null)
  const [attachments,setAttachments] = useState([])
  const [uploading,  setUploading]   = useState(false)
  const [sending,    setSending]     = useState(false)
  const [newChat,    setNewChat]     = useState(false)

  const inputRef   = useRef(null)
  const fileRef    = useRef(null)
  const msgListRef = useRef(null)

  const activeChat = chats.find(c => c.id === activeChatId)
  const activeMsgs = messages[activeChatId] || []
  const canDelete  = ['owner','admin'].includes(userProfile?.role)

  // Filter chats — admin sees all; DMs only if admin is a member
  const filtered = chats.filter(c => {
    const matchQ = (c.name || '').toLowerCase().includes(q.toLowerCase())
    if (!matchQ) return false
    if (c.isGroup) return true
    return canDelete || (c.members || []).includes(user?.uid)
  })

  // Scroll to bottom on new messages
  useEffect(() => {
    if (msgListRef.current) msgListRef.current.scrollTop = msgListRef.current.scrollHeight
    if (activeChatId && user) markChatRead(activeChatId, user.uid)
  }, [activeMsgs.length, activeChatId])

  // Handle file upload
  const handleFileUpload = async (e) => {
    const files = Array.from(e.target.files)
    if (!files.length) return
    setUploading(true)
    try {
      const added = []
      for (const f of files) {
        let processed = f
        try { processed = await resizeFile(f) } catch {}
        const snap = await uploadBytes(stRef(storage, `chat_attachments/${uid()}_${processed.name}`), processed)
        const url  = await getDownloadURL(snap.ref)
        added.push({ id: uid(), name: f.name, url, type: f.type })
      }
      setAttachments(prev => [...prev, ...added])
    } catch (e) { console.error(e) }
    finally { setUploading(false); if (fileRef.current) fileRef.current.value = '' }
  }

  // Send message
  const handleSend = async () => {
    if ((!msgText.trim() && !attachments.length) || !activeChatId || sending) return
    setSending(true)
    try {
      await sendMessage(activeChatId, {
        text: msgText.trim(),
        attachments,
        replyTo: replyTo ? { id: replyTo.id, text: replyTo.text, authorName: replyTo.authorName } : null,
        authorId:   user?.uid,
        authorName: `${userProfile?.firstName || ''} ${userProfile?.lastName || ''}`.trim(),
      })
      setMsgText(''); setAttachments([]); setReplyTo(null)
    } finally { setSending(false) }
  }

  // Forward message
  const handleForward = async (toChatId) => {
    if (!forwardMsg) return
    await sendMessage(toChatId, {
      text: forwardMsg.text,
      attachments: forwardMsg.attachments || [],
      replyTo: null,
      authorId:   user?.uid,
      authorName: `${userProfile?.firstName || ''} ${userProfile?.lastName || ''}`.trim(),
    })
  }

  // Unread count per chat
  const unread = (chat) => {
    const lastReadTs = chat.lastRead?.[user?.uid]?.seconds || 0
    return (messages[chat.id] || []).filter(m =>
      m.authorId !== user?.uid && (m.createdAt?.seconds || 0) > lastReadTs
    ).length
  }

  if (loading) return (
    <div className="flex-1 flex items-center justify-center bg-app">
      <div className="w-8 h-8 rounded-full border-2 border-accent border-t-transparent animate-spin" />
    </div>
  )

  return (
    <div className="flex-1 flex overflow-hidden bg-app">

      {/* ── Chat list ── */}
      <div className={`flex flex-col border-r border-app bg-surface flex-shrink-0
        ${showList ? 'flex' : 'hidden md:flex'}
        w-full md:w-72 lg:w-80`}>

        {/* List header */}
        <div className="px-4 pt-5 pb-3 border-b border-app flex-shrink-0">
          <div className="flex items-center justify-between mb-3">
            <h2 className="text-base font-bold text-primary">Messages</h2>
            <button onClick={() => setNewChat(true)}
              className="w-8 h-8 rounded-xl bg-accent-soft text-accent flex items-center justify-center cursor-pointer hover:bg-accent hover:text-white transition-colors text-lg border-none bg-transparent">
              ✏️
            </button>
          </div>
          <input value={q} onChange={e => setQ(e.target.value)} placeholder="Search…"
            className="w-full bg-raised border border-app rounded-xl px-3 py-2 text-sm text-primary placeholder:text-dim outline-none focus:border-accent" />
        </div>

        {/* Chat items */}
        <div className="flex-1 overflow-y-auto">
          {filtered.length === 0 ? (
            <div className="flex flex-col items-center justify-center py-16 text-center px-4">
              <p className="text-3xl mb-2">💬</p>
              <p className="text-sm text-muted">No conversations yet</p>
              <p className="text-xs text-dim mt-1">Click ✏️ to start one</p>
            </div>
          ) : filtered.map(chat => {
            const u = unread(chat)
            const isPinned = !!chat.pinnedAt
            return (
              <div key={chat.id}
                onClick={() => { setActiveChat(chat.id); setShowList(false) }}
                className={`group flex items-center gap-3 px-4 py-3 cursor-pointer border-b border-app/30 transition-colors relative
                  ${activeChatId === chat.id ? 'bg-accent-soft' : 'hover:bg-raised'}`}>
                {/* Avatar */}
                <div className="w-10 h-10 rounded-xl bg-raised border border-app flex items-center justify-center text-lg flex-shrink-0">
                  {chat.isGroup ? '👥' : '💬'}
                </div>
                {/* Info */}
                <div className="flex-1 min-w-0">
                  <div className="flex items-center gap-1">
                    {isPinned && <span className="text-xs text-accent">📌</span>}
                    <p className="text-sm font-semibold text-primary truncate">{chat.name}</p>
                  </div>
                  <p className="text-xs text-dim truncate mt-0.5">{chat.lastMessage || 'No messages yet'}</p>
                </div>
                {/* Badge + actions */}
                <div className="flex flex-col items-end gap-1 flex-shrink-0">
                  {u > 0 && (
                    <span className="min-w-[18px] h-[18px] rounded-full bg-accent text-white text-[9px] font-bold flex items-center justify-center px-1">
                      {u > 9 ? '9+' : u}
                    </span>
                  )}
                  <div className="hidden group-hover:flex items-center gap-1">
                    <button onClick={e => { e.stopPropagation(); pinChat(chat.id, !chat.pinnedAt) }}
                      className="text-xs p-1 rounded hover:bg-raised cursor-pointer bg-transparent border-none text-muted"
                      title={isPinned ? 'Unpin' : 'Pin'}>
                      {isPinned ? '📍' : '📌'}
                    </button>
                    {(canDelete || chat.createdBy === user?.uid) && (
                      <button onClick={e => { e.stopPropagation(); if (window.confirm('Delete this chat?')) { deleteChat(chat.id); if (activeChatId === chat.id) setActiveChat(null) } }}
                        className="text-xs p-1 rounded hover:bg-danger-soft cursor-pointer bg-transparent border-none text-danger"
                        title="Delete">🗑</button>
                    )}
                  </div>
                </div>
              </div>
            )
          })}
        </div>
      </div>

      {/* ── Message pane ── */}
      <div className={`flex-1 flex flex-col overflow-hidden
        ${!showList ? 'flex' : 'hidden md:flex'}`}>

        {!activeChatId ? (
          <div className="flex-1 flex flex-col items-center justify-center text-center p-8">
            <p className="text-5xl mb-4">💬</p>
            <p className="text-lg font-bold text-muted">Select a conversation</p>
            <p className="text-sm text-dim mt-1">Choose from the list or start a new one</p>
          </div>
        ) : (
          <>
            {/* Chat header */}
            <div className="flex items-center gap-3 px-4 py-3 bg-surface border-b border-app flex-shrink-0">
              <button onClick={() => { setShowList(true); setActiveChat(null) }}
                className="md:hidden w-8 h-8 rounded-xl bg-raised border border-app flex items-center justify-center text-muted cursor-pointer text-lg border-none bg-transparent">
                ‹
              </button>
              <div className="w-9 h-9 rounded-xl bg-accent-soft flex items-center justify-center text-base flex-shrink-0">
                {activeChat?.isGroup ? '👥' : '💬'}
              </div>
              <div className="flex-1 min-w-0">
                <p className="text-sm font-bold text-primary truncate">{activeChat?.name}</p>
                <p className="text-xs text-dim">
                  {activeChat?.isGroup ? `${activeChat?.members?.length || 0} members` : 'Direct message'}
                </p>
              </div>
              {(canDelete || activeChat?.createdBy === user?.uid) && (
                <button onClick={() => { if (window.confirm('Delete this chat?')) { deleteChat(activeChatId); setActiveChat(null); setShowList(true) } }}
                  className="w-8 h-8 rounded-xl flex items-center justify-center text-danger cursor-pointer bg-transparent border-none hover:bg-danger-soft"
                  title="Delete chat">🗑</button>
              )}
            </div>

            {/* Messages */}
            <div ref={msgListRef} className="flex-1 overflow-y-auto px-4 py-4">
              {activeMsgs.length === 0 ? (
                <div className="flex items-center justify-center h-full">
                  <p className="text-sm text-muted">No messages yet — say hello!</p>
                </div>
              ) : activeMsgs.map(msg => {
                const isMine = msg.authorId === user?.uid
                return (
                  <div key={msg.id}>
                    {!isMine && activeChat?.isGroup && (
                      <p className="text-xs text-muted font-semibold mb-1 ml-1">{msg.authorName}</p>
                    )}
                    <Bubble
                      msg={msg}
                      isMine={isMine}
                      onReact={(emoji) => addReaction(activeChatId, msg.id, emoji, user?.uid)}
                      onReply={() => { setReplyTo(msg); inputRef.current?.focus() }}
                      onForward={() => setForwardMsg(msg)}
                      onDelete={isMine ? () => deleteMessage(activeChatId, msg.id) : canDelete ? () => deleteMessage(activeChatId, msg.id) : null}
                    />
                  </div>
                )
              })}
            </div>

            {/* Reply preview */}
            {replyTo && (
              <div className="flex items-center gap-2 px-4 py-2 bg-raised border-t border-app flex-shrink-0">
                <div className="flex-1 border-l-2 border-accent pl-2">
                  <p className="text-xs font-semibold text-accent">{replyTo.authorName}</p>
                  <p className="text-xs text-dim truncate">{replyTo.text || '📎 Attachment'}</p>
                </div>
                <button onClick={() => setReplyTo(null)}
                  className="text-dim text-lg cursor-pointer bg-transparent border-none">×</button>
              </div>
            )}

            {/* Attachment previews */}
            {attachments.length > 0 && (
              <div className="flex gap-2 px-4 py-2 border-t border-app flex-shrink-0 flex-wrap">
                {attachments.map(a => (
                  <div key={a.id} className="flex items-center gap-1.5 px-2.5 py-1.5 bg-raised border border-app rounded-xl text-xs">
                    <span>{a.type?.startsWith('image/') ? '🖼️' : '📄'}</span>
                    <span className="text-muted max-w-[100px] truncate">{a.name}</span>
                    <button onClick={() => setAttachments(prev => prev.filter(x => x.id !== a.id))}
                      className="text-dim cursor-pointer bg-transparent border-none ml-1">×</button>
                  </div>
                ))}
              </div>
            )}

            {/* Input */}
            <div className="px-4 py-3 bg-surface border-t border-app flex items-end gap-2 flex-shrink-0">
              <button onClick={() => fileRef.current?.click()} disabled={uploading}
                className="w-9 h-9 rounded-xl bg-raised border border-app flex items-center justify-center text-muted cursor-pointer hover:border-accent flex-shrink-0 disabled:opacity-50 bg-transparent">
                {uploading ? '⏳' : '📎'}
              </button>
              <input ref={fileRef} type="file" multiple accept="image/*,video/*,.pdf" className="hidden" onChange={handleFileUpload} />
              <div className="flex-1 bg-raised border border-app rounded-2xl px-3.5 py-2.5">
                <textarea ref={inputRef} value={msgText}
                  onChange={e => setMsgText(e.target.value)}
                  placeholder="Type a message…" rows={1}
                  onKeyDown={e => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); handleSend() } }}
                  style={{ resize: 'none', maxHeight: 120, overflow: 'auto' }}
                  className="w-full bg-transparent text-sm text-primary placeholder:text-dim outline-none resize-none" />
              </div>
              <button onClick={handleSend}
                disabled={(!msgText.trim() && !attachments.length) || sending}
                className="w-9 h-9 rounded-xl bg-accent text-white flex items-center justify-center text-sm cursor-pointer border-none disabled:opacity-40 flex-shrink-0 hover:opacity-90">
                {sending ? '…' : '➤'}
              </button>
            </div>
          </>
        )}
      </div>

      {/* Modals */}
      {newChat && (
        <NewChatModal
          onClose={() => setNewChat(false)}
          onCreate={createChat}
          adminId={user?.uid}
          userProfile={userProfile}
        />
      )}
      {forwardMsg && (
        <ForwardModal
          msg={forwardMsg}
          chats={chats}
          activeChatId={activeChatId}
          onForward={handleForward}
          onClose={() => setForwardMsg(null)}
        />
      )}
    </div>
  )
}
